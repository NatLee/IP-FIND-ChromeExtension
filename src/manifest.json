{
  "manifest_version": 3,
  "name": "IP Find",
  "version": "4.0",
  "description": "Look up your IP and any other IP — with location, ISP, ASN, timezone and more.",
  "permissions": ["clipboardWrite", "clipboardRead"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "24": "icons/icon.png"
    }
  },
  "icons": {
    "24": "icons/icon.png"
  }
}
